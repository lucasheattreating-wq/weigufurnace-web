---
const { title = "Need a Methanol Dropper for Your Furnace?", href = "/contact-us/" } = Astro.props;
---
<section style="background: #00234b; color: white; padding: 4rem 2rem; text-align: center; margin-top: 4rem;">
  <div style="max-width: 800px; margin: 0 auto;">
    <h2 style="font-size: 2rem; margin-bottom: 1rem;">{title}</h2>
    <p style="margin-bottom: 2rem; opacity: 0.9;">Send us your furnace type, medium, and connection requirements for a quick quote.</p>
    <a href={href} style="background: #ff8c00; color: white; padding: 1rem 2rem; border-radius: 4px; text-decoration: none; font-weight: bold;">Request a Quote</a>
  </div>
</section>
