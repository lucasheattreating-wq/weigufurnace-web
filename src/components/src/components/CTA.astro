---
const { title, href } = Astro.props;
---
<section class="cta-section">
  <div class="container">
    <h2>{title || "Need a Methanol Dropper for Your Furnace?"}</h2>
    <p>Send us your furnace type, medium, and connection requirements for a quick quote.</p>
    <a href={href || "/contact-us/"} class="btn btn-primary">Request a Quote</a>
  </div>
</section>
