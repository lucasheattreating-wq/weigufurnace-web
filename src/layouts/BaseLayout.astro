---
import "../styles/global.css";
import { navigation, siteConfig } from '../data/navigation';
const { title, description } = Astro.props;


// SEO Checklist Rule: All titles Capitalize Each Word
const capitalizedTitle = title.split(' ').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
---


<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{capitalizedTitle} | {siteConfig.name}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-gray-50 font-sans text-gray-900">
    <header class="bg-primary text-white sticky top-0 z-50 shadow-lg">
      <div class="container mx-auto px-4 h-20 flex items-center justify-between">
        <a href="/" class="text-2xl font-bold flex items-center gap-2">
          <div class="w-8 h-8 bg-accent rotate-45"></div>
          WEIGU
        </a>
        
        <nav class="hidden md:flex gap-8">
          {navigation.map(item => (
            <div class="group relative">
              <a href={item.href} class="hover:text-accent font-semibold transition-colors">
                {item.name}
              </a>
              {item.children && (
                <div class="absolute top-full left-0 bg-white text-gray-800 shadow-xl border border-gray-100 hidden group-hover:block min-w-[220px] p-2 rounded-b">
                  {item.children.map(child => (
                    <a href={child.href} class="block px-4 py-2 hover:bg-gray-50 hover:text-accent rounded transition-colors text-sm">
