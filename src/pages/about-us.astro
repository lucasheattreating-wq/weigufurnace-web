---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'About Us | Methanol Dropper Manufacturer';
const description = 'Manufacturer and supplier of stainless steel methanol droppers for heat treatment furnaces and carburizing furnace atmosphere control.';
---
<BaseLayout title={title} description={description}>
<section class="section"><div class="container"><p class="eyebrow">About Us</p><h1 class="h1">Focused on Methanol Droppers for Furnace Applications</h1><p class="lead">We supply stainless steel methanol droppers, drip valves, sight glass components, insertion tubes, and repair kits for heat treatment and furnace atmosphere control applications.</p></div></section>
<section class="section gray"><div class="container grid grid-3"><div class="card"><h2>Focused Product</h2><p>We focus on methanol dropper configurations instead of broad unrelated product categories.</p></div><div class="card"><h2>Application Support</h2><p>Support for carburizing, pit furnace, box furnace, roller furnace, and mesh belt furnace use cases.</p></div><div class="card"><h2>Export Packaging</h2><p>Protective packaging for stainless steel and glass components during international shipment.</p></div></div></section>
</BaseLayout>
