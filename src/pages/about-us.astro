---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About WEIGU | Heat Treatment Furnace Accessories Expert">
  <main class="container mx-auto px-4 py-16">
    <div class="max-w-4xl mx-auto">
      <p class="text-orange-600 font-bold uppercase tracking-widest text-sm mb-4">Furnace Process Stability Specialist</p>
      <h1 class="text-4xl md:text-5xl font-extrabold text-blue-900 mb-8 leading-tight">About WEIGU</h1>
      
      <div class="prose prose-lg max-w-none text-gray-600 mb-12">
        <p>
          You are partnering with a leader in the industrial furnace consumable industry. At WEIGU, we focus on providing you with high-quality thermal processing accessories that ensure the stability of your heat treatment furnace. You can trust our expertise in atmosphere control and temperature measurement to help you achieve reliable manufacturing results every day.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 text-center">
          <h2 class="text-4xl font-bold text-blue-900 mb-2">20+</h2>
          <p class="text-gray-500 font-medium">Years Expertise</p>
        </div>
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 text-center">
          <h2 class="text-4xl font-bold text-blue-900 mb-2">500+</h2>
          <p class="text-gray-500 font-medium">Factories Served</p>
        </div>
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 text-center">
          <h2 class="text-4xl font-bold text-blue-900 mb-2">100%</h2>
          <p class="text-gray-500 font-medium">Stability Focus</p>
        </div>
      </div>

      <section class="bg-gray-50 p-10 rounded-3xl border border-gray-100 shadow-inner">
        <h2 class="text-3xl font-bold text-blue-900 mb-6">Our Commitment To Your Factory</h2>
        <p class="text-gray-600 leading-relaxed mb-8">
          We understand that even the smallest accessory failure can disrupt your entire production line. That's why we invite you to explore our <a href="/applications/" class="text-orange-600 font-bold underline">Applications Hub</a> or see <a href="/why-weigu/" class="text-orange-600 font-bold underline">Why Choose WEIGU</a> to see how we guarantee precision and zero-risk procurement for your heat treatment workshop.
        </p>
      </section>
    </div>
  </main>
</BaseLayout>
