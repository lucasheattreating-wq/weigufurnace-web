---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { images, applications } from '../../data/site';
---


<BaseLayout title="Furnace Applications" description="Precision methanol dropper applications for various industrial furnaces.">
  <section class="section section-alt">
    <div class="container">
      <p style="color: var(--accent); font-weight: 600; text-transform: uppercase; margin-bottom: 1rem;">Solutions Hub</p>
      <h1>Optimized for Every Furnace Type</h1>
      <p style="font-size: 1.2rem; color: var(--text-muted); max-width: 700px; margin-bottom: 3rem;">
        You deserve heating solutions that match the complexity of your metal processing needs. Whether you are operating high-capacity carburizing furnaces or precision box furnaces, our atmosphere control kits are designed to ensure your process stays stable and repeatable.
      </p>


      <div class="grid grid-3">
        {applications.map((app) => (
          <div class="card">
            <h3 style="margin-bottom: 1rem;">{app}</h3>
            <p style="color: var(--text-muted); font-size: 0.95rem; margin-bottom: 1.5rem;">
              Controlled liquid feeding for {app.toLowerCase()} atmosphere stability.
            </p>
            <a href="/contact-us/" style="color: var(--accent); text-decoration: none; font-weight: 600;">Learn More →</a>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
