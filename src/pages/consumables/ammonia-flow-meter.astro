---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTA from '../../components/CTA.astro';

const { 
  name = "Precision Ammonia Flow Meter For Nitriding Process", 
  slug = "ammonia-flow-meter",
  desc = "Accurate ammonia gas flow measurement for furnace atmosphere control.",
  specs = [
    { label: "Flow Range", value: "0.1 - 100 L/min (Custom)" },
    { label: "Accuracy", value: "Class 1.5 Industrial Grade" },
    { label: "Material", value: "Glass / Polycarbonate / SS" },
    { label: "Scale Type", value: "Dual Scale (Ammonia Specific)" }
  ]
} = Astro.props;
---

<BaseLayout title={name} description={desc}>
  <main class="container mx-auto px-4 py-12">
    <div class="flex flex-col lg:flex-row gap-16 items-start mb-20">
      <div class="flex-1 bg-gray-100 aspect-square rounded-2xl flex items-center justify-center text-gray-400 border-2 border-dashed border-gray-200">
        Product Image: {name}
      </div>
      <div class="flex-1">
        <h1 class="text-4xl font-extrabold text-blue-900 mb-6 leading-tight">{name}</h1>
        <p class="text-lg text-gray-600 mb-8 leading-relaxed">
          You need consistent ammonia gas flow to achieve the perfect nitrided case on your metal parts. Our {name} provides you with a clear, accurate reading of your gas consumption, ensuring your furnace atmosphere remains within critical metallurgical parameters. You will notice a marked improvement in the uniformity of your nitriding cycles by implementing our precision flow control solutions.
        </p>
        
        <div class="bg-blue-900 text-white p-8 rounded-xl mb-8 shadow-xl">
          <h2 class="text-sm font-bold uppercase tracking-widest text-orange-400 mb-4">Technical Specifications</h2>
          <div class="space-y-3">
            {specs.map(spec => (
              <div class="flex justify-between border-b border-blue-800 pb-2">
                <span class="font-medium">{spec.label}</span>
                <span class="text-orange-200 font-bold">{spec.value}</span>
              </div>
            ))}
          </div>
        </div>
        
        <a href="/contact/" class="w-full block bg-orange-600 hover:bg-orange-700 text-white text-center py-4 rounded-lg font-black text-xl transition-all shadow-lg shadow-orange-900/20">
          Request A Technical Quote
        </a>
      </div>
    </div>

    <div class="prose prose-lg max-w-none mb-20">
      <h2 class="text-3xl font-bold text-blue-900 mb-6 border-l-8 border-orange-500 pl-6">Reliable Gas Monitoring For Industrial Furnaces</h2>
      <p>You can trust Weigu to provide gas measurement tools that handle the rigorous demands of your workshop floor. Our ammonia flow meters are built with chemically resistant materials to ensure long-term stability without fogging or scale degradation. Whether you are upgrading an existing pit furnace or building a new nitriding line, our meters offer the accuracy and durability your process requires.</p>
    </div>

    <CTA title={`Master Your Nitriding Process With ${name}`} />
  </main>
</BaseLayout>
