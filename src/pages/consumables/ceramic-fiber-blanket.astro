---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTA from '../../components/CTA.astro';

const { 
  name = "High-Density Ceramic Fiber Blanket For Furnace Lining", 
  slug = "ceramic-fiber-blanket",
  desc = "Superior thermal insulation blankets for heat treatment furnace linings.",
  specs = [
    { label: "Service Temp", value: "1050°C / 1260°C / 1430°C Options" },
    { label: "Density", value: "96kg/m³ / 128kg/m³ / 160kg/m³" },
    { label: "Thickness", value: "10mm / 25mm / 50mm" },
    { label: "Chemistry", value: "High Alumina / Al-Si / Zirconia" }
  ]
} = Astro.props;
---

<BaseLayout title={name} description={desc}>
  <main class="container mx-auto px-4 py-12">
    <div class="flex flex-col lg:flex-row gap-16 items-start mb-20">
      <div class="flex-1 bg-gray-100 aspect-square rounded-2xl flex items-center justify-center text-gray-400 border-2 border-dashed border-gray-200">
        Product Image: {name}
      </div>
      <div class="flex-1">
        <h1 class="text-4xl font-extrabold text-blue-900 mb-6 leading-tight">{name}</h1>
        <p class="text-lg text-gray-600 mb-8 leading-relaxed">
          You need superior thermal insulation to maximize your furnace's energy efficiency and protect its outer shell from overheating. Our {name} are engineered for low thermal conductivity and excellent resistance to thermal shock. By choosing Weigu ceramic fiber products, you reduce your factory's fuel or electricity consumption and ensure a faster heating cycle for your pit furnaces, box furnaces, and industrial kilns.
        </p>
        
        <div class="bg-blue-900 text-white p-8 rounded-xl mb-8 shadow-xl">
          <h2 class="text-sm font-bold uppercase tracking-widest text-orange-400 mb-4">Technical Specifications</h2>
          <div class="space-y-3">
            {specs.map(spec => (
              <div class="flex justify-between border-b border-blue-800 pb-2">
                <span class="font-medium">{spec.label}</span>
                <span class="text-orange-200 font-bold">{spec.value}</span>
              </div>
            ))}
          </div>
        </div>
        
        <a href="/contact/" class="w-full block bg-orange-600 hover:bg-orange-700 text-white text-center py-4 rounded-lg font-black text-xl transition-all shadow-lg shadow-orange-900/20">
          Request A Technical Quote
        </a>
      </div>
    </div>

    <div class="prose prose-lg max-w-none mb-20">
      <h2 class="text-3xl font-bold text-blue-900 mb-6 border-l-8 border-orange-500 pl-6">Advanced Thermal Shielding For Industrial Efficiency</h2>
      <p>You require lightweight insulation that can be easily installed and maintained without risking mechanical failure at high temperatures. Our blankets are double-needle punched to ensure high tensile strength and integrity during high-velocity gas flow. Whether you are performing a complete furnace reline or a minor technical guide repair, Weigu provides the high-grade fiber solutions needed to maintain consistent thermal performance across your operations.</p>
    </div>

    <CTA title={`Upgrade Your Furnace Insulation With ${name}`} />
  </main>
</BaseLayout>
