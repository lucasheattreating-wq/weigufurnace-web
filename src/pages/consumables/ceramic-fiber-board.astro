---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTA from '../../components/CTA.astro';

const { 
  name = "Rigid Ceramic Fiber Board For Furnace Insulation", 
  slug = "ceramic-fiber-board",
  desc = "High-strength rigid insulation boards for furnace backups and hot-faces.",
  specs = [
    { label: "Comp. Strength", value: "> 0.5 MPa" },
    { label: "Max Operating Temp", value: "Up to 1600°C" },
    { label: "Size Options", value: "Standard 600x900 / Custom" },
    { label: "Machinability", value: "Easy To Cut / Drill / Shape" }
  ]
} = Astro.props;
---

<BaseLayout title={name} description={desc}>
  <main class="container mx-auto px-4 py-12">
    <div class="flex flex-col lg:flex-row gap-16 items-start mb-20">
      <div class="flex-1 bg-gray-100 aspect-square rounded-2xl flex items-center justify-center text-gray-400 border-2 border-dashed border-gray-200">
        Product Image: {name}
      </div>
      <div class="flex-1">
        <h1 class="text-4xl font-extrabold text-blue-900 mb-6 leading-tight">{name}</h1>
        <p class="text-lg text-gray-600 mb-8 leading-relaxed">
          You need rigid, high-strength insulation to provide a stable hot-face or reliable backup for your industrial furnace lining. Our {name} are vacuum-formed from high-quality ceramic fibers to provide superior structural integrity and excellent thermal resistance. By implementing Weigu rigid boards, you ensure that your furnace lining remains stable under gas erosion and mechanical vibrations, prolonging the operational life of your heat treatment equipment.
        </p>
        
        <div class="bg-blue-900 text-white p-8 rounded-xl mb-8 shadow-xl">
          <h2 class="text-sm font-bold uppercase tracking-widest text-orange-400 mb-4">Technical Specifications</h2>
          <div class="space-y-3">
            {specs.map(spec => (
              <div class="flex justify-between border-b border-blue-800 pb-2">
                <span class="font-medium">{spec.label}</span>
                <span class="text-orange-200 font-bold">{spec.value}</span>
              </div>
            ))}
          </div>
        </div>
        
        <a href="/contact/" class="w-full block bg-orange-600 hover:bg-orange-700 text-white text-center py-4 rounded-lg font-black text-xl transition-all shadow-lg shadow-orange-900/20">
          Request A Technical Quote
        </a>
      </div>
    </div>

    <div class="prose prose-lg max-w-none mb-20">
      <h2 class="text-3xl font-bold text-blue-900 mb-6 border-l-8 border-orange-500 pl-6">Industrial Grade Rigid Insulation Solutions</h2>
      <p>You require insulation that can be precisely machined to fit around heating element supports, radiant tubes, or complex door seals. Our boards feature excellent consistency and low shrinkage, ensuring that your thermal shield remains effective even after hundreds of heating cycles. From specialized laboratory kilns to high-capacity roller hearth furnaces, Weigu provides the rigid insulation boards your facility needs to maintain process precision.</p>
    </div>

    <CTA title={`Optimize Your Thermal Shielding With ${name}`} />
  </main>
</BaseLayout>
