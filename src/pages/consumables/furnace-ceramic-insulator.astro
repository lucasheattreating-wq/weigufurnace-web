---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTA from '../../components/CTA.astro';

const { 
  name = "Industrial Furnace Ceramic Insulators For Heating Elements", 
  slug = "furnace-ceramic-insulator",
  desc = "High-purity alumina ceramic insulators for electrical insulation in furnaces.",
  specs = [
    { label: "Material", value: "95% - 99% Alumina (Al2O3)" },
    { label: "Max Temp", value: "1600°C - 1800°C" },
    { label: "Voltage Rating", value: "High-Voltage Industrial Spec" },
    { label: "Design", value: "Single / Multi-Hole Configurations" }
  ]
} = Astro.props;
---

<BaseLayout title={name} description={desc}>
  <main class="container mx-auto px-4 py-12">
    <div class="flex flex-col lg:flex-row gap-16 items-start mb-20">
      <div class="flex-1 bg-gray-100 aspect-square rounded-2xl flex items-center justify-center text-gray-400 border-2 border-dashed border-gray-200">
        Product Image: {name}
      </div>
      <div class="flex-1">
        <h1 class="text-4xl font-extrabold text-blue-900 mb-6 leading-tight">{name}</h1>
        <p class="text-lg text-gray-600 mb-8 leading-relaxed">
          You need reliable electrical insulation to prevent short circuits and costly damage to your furnace heating systems. Our {name} are manufactured from high-purity alumina to ensure maximum dielectric strength and thermal shock resistance. By implementing Weigu ceramic insulators, you guarantee the safety and operational stability of your box furnace, pit furnace, or continuous production line today.
        </p>
        
        <div class="bg-blue-900 text-white p-8 rounded-xl mb-8 shadow-xl">
          <h2 class="text-sm font-bold uppercase tracking-widest text-orange-400 mb-4">Technical Specifications</h2>
          <div class="space-y-3">
            {specs.map(spec => (
              <div class="flex justify-between border-b border-blue-800 pb-2">
                <span class="font-medium">{spec.label}</span>
                <span class="text-orange-200 font-bold">{spec.value}</span>
              </div>
            ))}
          </div>
        </div>
        
        <a href="/contact/" class="w-full block bg-orange-600 hover:bg-orange-700 text-white text-center py-4 rounded-lg font-black text-xl transition-all shadow-lg shadow-orange-900/20">
          Request A Technical Quote
        </a>
      </div>
    </div>

    <div class="prose prose-lg max-w-none mb-20">
      <h2 class="text-3xl font-bold text-blue-900 mb-6 border-l-8 border-orange-500 pl-6">Reliable Dielectric Performance For Industrial Heating</h2>
      <p>You require high-grade ceramics to withstand the mechanical stress of installation and the thermal stress of rapid cycling. Our insulators are precision-fired to minimize porosity and maximize durability in carbon-rich or vacuum atmospheres. Whether you are repairing an existing heating element support or designing a new furnace chamber, Weigu provides the exact ceramic configuration to keep your process running safely.</p>
    </div>

    <CTA title={`Secure Your Heating System With ${name}`} />
  </main>
</BaseLayout>
