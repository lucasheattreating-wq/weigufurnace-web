---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTA from '../../components/CTA.astro';

const { 
  name = "Precision Heat Treatment Process Verification Rings", 
  slug = "heat-treatment-verification-ring",
  desc = "Reliable process control rings for verifying thermal cycles and uniformity.",
  specs = [
    { label: "Temp Range", value: "850°C to 1750°C (Various Types)" },
    { label: "Measurement", value: "Precise Diameter Shrinkage Analysis" },
    { label: "Quantity", value: "Supplied in Certified Batches" },
    { label: "Accuracy", value: "Traceable Thermal Feedback" }
  ]
} = Astro.props;
---

<BaseLayout title={name} description={desc}>
  <main class="container mx-auto px-4 py-12">
    <div class="flex flex-col lg:flex-row gap-16 items-start mb-20">
      <div class="flex-1 bg-gray-100 aspect-square rounded-2xl flex items-center justify-center text-gray-400 border-2 border-dashed border-gray-200">
        Product Image: {name}
      </div>
      <div class="flex-1">
        <h1 class="text-4xl font-extrabold text-blue-900 mb-6 leading-tight">{name}</h1>
        <p class="text-lg text-gray-600 mb-8 leading-relaxed">
          You need an objective, reliable method to verify that your heat treatment process is achieving the exact thermal work required for quality assurance. Our {name} provide you with precise feedback on temperature uniformity and total heat input, allowing you to identify process deviations before they result in quality rejects. By implementing Weigu's verification rings, you ensure that every batch from your pit furnace or continuous line meets your customer's stringent metallurgical standards.
        </p>
        
        <div class="bg-blue-900 text-white p-8 rounded-xl mb-8 shadow-xl">
          <h2 class="text-sm font-bold uppercase tracking-widest text-orange-400 mb-4">Technical Specifications</h2>
          <div class="space-y-3">
            {specs.map(spec => (
              <div class="flex justify-between border-b border-blue-800 pb-2">
                <span class="font-medium">{spec.label}</span>
                <span class="text-orange-200 font-bold">{spec.value}</span>
              </div>
            ))}
          </div>
        </div>
        
        <a href="/contact/" class="w-full block bg-orange-600 hover:bg-orange-700 text-white text-center py-4 rounded-lg font-black text-xl transition-all shadow-lg shadow-orange-900/20">
          Request A Technical Quote
        </a>
      </div>
    </div>

    <div class="prose prose-lg max-w-none mb-20">
      <h2 class="text-3xl font-bold text-blue-900 mb-6 border-l-8 border-orange-500 pl-6">Objective Thermal Verification For Process Stability</h2>
      <p>You require high-accuracy verification tools to maintain the competitive edge and certification status of your heat treatment facility. Our process control rings are manufactured under strict conditions to ensure traceable and repeatable results across a wide temperature spectrum. From complex aerospace parts in vacuum furnaces to high-volume automotive components in belt furnaces, Weigu provides the objective verification tools your facility needs to maintain total process precision.</p>
    </div>

    <CTA title={`Validate Your Thermal Cycles With ${name}`} />
  </main>
</BaseLayout>
