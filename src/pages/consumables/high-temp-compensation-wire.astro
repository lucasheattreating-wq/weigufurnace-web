---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTA from '../../components/CTA.astro';

const { 
  name = "High-Temperature Thermocouple Compensation Wire", 
  slug = "high-temp-compensation-wire",
  desc = "Reliable compensation and extension wires for accurate temperature recording.",
  specs = [
    { label: "Wire Types", value: "K, S, R, B, J, T Types" },
    { label: "Insulation", value: "Fiberglass / PTFE / Silicone / SS Braided" },
    { label: "Temp Range", value: "-60°C to +400°C (Insulation Dependent)" },
    { label: "Compliance", value: "ASTM / ANSI / IEC Standards" }
  ]
} = Astro.props;
---

<BaseLayout title={name} description={desc}>
  <main class="container mx-auto px-4 py-12">
    <div class="flex flex-col lg:flex-row gap-16 items-start mb-20">
      <div class="flex-1 bg-gray-100 aspect-square rounded-2xl flex items-center justify-center text-gray-400 border-2 border-dashed border-gray-200">
        Product Image: {name}
      </div>
      <div class="flex-1">
        <h1 class="text-4xl font-extrabold text-blue-900 mb-6 leading-tight">{name}</h1>
        <p class="text-lg text-gray-600 mb-8 leading-relaxed">
          You need accurate signal transmission from your furnace sensors to your controllers to ensure process repeatability. Our {name} are designed to eliminate signal noise and thermal interference, providing the precision your heat treatment quality control demands. By utilizing Weigu's high-quality compensation wires, you avoid the temperature drifting and measurement errors that lead to batch quality failures in your workshop.
        </p>
        
        <div class="bg-blue-900 text-white p-8 rounded-xl mb-8 shadow-xl">
          <h2 class="text-sm font-bold uppercase tracking-widest text-orange-400 mb-4">Technical Specifications</h2>
          <div class="space-y-3">
            {specs.map(spec => (
              <div class="flex justify-between border-b border-blue-800 pb-2">
                <span class="font-medium">{spec.label}</span>
                <span class="text-orange-200 font-bold">{spec.value}</span>
              </div>
            ))}
          </div>
        </div>
        
        <a href="/contact/" class="w-full block bg-orange-600 hover:bg-orange-700 text-white text-center py-4 rounded-lg font-black text-xl transition-all shadow-lg shadow-orange-900/20">
          Request A Technical Quote
        </a>
      </div>
    </div>

    <div class="prose prose-lg max-w-none mb-20">
      <h2 class="text-3xl font-bold text-blue-900 mb-6 border-l-8 border-orange-500 pl-6">Precision Signal Transmission For Furnace Controllers</h2>
      <p>You require durable cabling that can withstand the oily and high-temperature environments of an industrial heat treatment facility. Our wires feature heavy-duty shielding and specialized insulation materials to protect against abrasion and chemical exposure. From multi-point recording systems in mesh belt lines to single-probe monitoring in pit furnaces, Weigu provides the reliable wiring solutions your facility needs to maintain process integrity.</p>
    </div>

    <CTA title={`Optimize Your Temp Recording With ${name}`} />
  </main>
</BaseLayout>
