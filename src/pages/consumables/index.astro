---
import BaseLayout from '../../layouts/BaseLayout.astro';

const products = [
  { title: "Alumina Crucible Lab Use", icon: "🧪", link: "/consumables/alumina-crucible-lab-use/" },
  { title: "Ammonia Flow Meter", icon: "📊", link: "/consumables/ammonia-flow-meter/" },
  { title: "Atmosphere Gas Manifold", icon: "💨", link: "/consumables/atmosphere-gas-manifold/" },
  { title: "Ceramic Fiber Blanket", icon: "🧶", link: "/consumables/ceramic-fiber-blanket/" },
  { title: "Ceramic Fiber Board", icon: "🧱", link: "/consumables/ceramic-fiber-board/" },
  { title: "Furnace Base Casting", icon: "🏗️", link: "/consumables/furnace-base-casting/" },
  { title: "Furnace Ceramic Insulator", icon: "⚡", link: "/consumables/furnace-ceramic-insulator/" },
  { title: "Furnace Door Sealing Gasket", icon: "🚪", link: "/consumables/furnace-door-sealing-gasket/" },
  { title: "Furnace Fan Impeller", icon: "🌀", link: "/consumables/furnace-fan-impeller/" },
  { title: "Furnace Heating Element Support", icon: "🏗️", link: "/consumables/furnace-heating-element-support/" },
  { title: "Furnace Muffle Tube", icon: "🧪", link: "/consumables/furnace-muffle-tube/" },
  { title: "Furnace Peep Hole Glass", icon: "👁️", link: "/consumables/furnace-peep-hole-glass/" },
  { title: "Graphite Crucible High Purity", icon: "🌚", link: "/consumables/graphite-crucible-high-purity/" },
  { title: "Heat Resistant Steel Basket", icon: "🧺", link: "/consumables/heat-resistant-steel-basket/" },
  { title: "Heat Treatment Verification Ring", icon: "⭕", link: "/consumables/heat-treatment-verification-ring/" },
  { title: "High Temp Compensation Wire", icon: "🔌", link: "/consumables/high-temp-compensation-wire/" },
  { title: "High Temp Furnace Paint", icon: "🎨", link: "/consumables/high-temp-furnace-paint/" },
  { title: "Kerosene Drip Feeder", icon: "💧", link: "/consumables/kerosene-drip-feeder/" },
  { title: "Lab Tube Furnace Flange", icon: "🔩", link: "/consumables/lab-tube-furnace-flange/" },
  { title: "Methanol Drip Feeder Kit", icon: "🛠️", link: "/consumables/methanol-drip-feeder-kit/" },
  { title: "Methanol Drip Feeder", icon: "💧", link: "/consumables/methanol-drip-feeder/" },
  { title: "MoSi2 Heating Element", icon: "🔥", link: "/consumables/mosi2-heating-element/" },
  { title: "Pressure Relief Valve", icon: "🎈", link: "/consumables/pressure-relief-valve/" },
  { title: "Radiant Tube Heater", icon: "⭕", link: "/consumables/radiant-tube-heater/" },
  { title: "Refractory Anchor Bolt", icon: "🔩", link: "/consumables/refractory-anchor-bolt/" },
  { title: "SiC Heating Element", icon: "🔥", link: "/consumables/sic-heating-element/" },
  { title: "Thermocouple Head Connection", icon: "🌡️", link: "/consumables/thermocouple-head-connection/" },
  { title: "Thermocouple Protection Tube", icon: "🌡️", link: "/consumables/thermocouple-protection-tube/" },
  { title: "Vacuum Grease High Temp", icon: "🧴", link: "/consumables/vacuum-grease-high-temp/" }
];
---

<BaseLayout title="Consumables For Industrial Furnaces">
  <main class="container mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold mb-6">Consumables For Industrial Furnaces</h1>
    <p class="text-lg mb-8">
      When you operate high-performance heat treatment equipment, you need reliable components that can withstand extreme temperatures. You will find that our premium selection of furnace consumables ensures your production line remains efficient and downtime is minimized. Explore our range of heating elements, insulation, and atmosphere control parts designed specifically for your demanding industrial applications.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {products.map(product => (
        <a href={product.link} class="border p-6 rounded-lg hover:shadow-lg transition">
          <span class="text-3xl mb-4 block">{product.icon}</span>
          <h3 class="text-xl font-semibold mb-2">{product.title}</h3>
          <p class="text-gray-600">Upgrade your furnace with high-quality {product.title.toLowerCase()}.</p>
        </a>
      ))}
    </div>
    
    <div class="mt-12">
      <h2 class="text-2xl font-bold mb-4">Support For Your Operations</h2>
      <p>
        If you are unsure which component fits your specific furnace model, you can check our <a href="/contact" class="text-blue-600 underline">Technical Support</a> or learn more <a href="/why-weigu" class="text-blue-600 underline">Why Weigu</a> and our commitment to quality.
      </p>
    </div>
  </main>
</BaseLayout>
