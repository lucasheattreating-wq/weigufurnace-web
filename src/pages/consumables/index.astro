---
import BaseLayout from '../../layouts/BaseLayout.astro';

const categories = [
  { title: "Heating Elements", icon: "ð¥", link: "/consumables/heating-elements" },
  { title: "Insulation Boards", icon: "ð§±", link: "/consumables/insulation" },
  { title: "Thermocouples", icon: "ð¡ï¸", link: "/consumables/thermocouples" },
  { title: "Atmosphere Feeders", icon: "ð§", link: "/consumables/methanol-drip-feeder" },
  { title: "Radiant Tubes", icon: "â­", link: "/consumables/radiant-tubes" },
  { title: "Furnace Hearth", icon: "ð ", link: "/consumables/hearth" }
