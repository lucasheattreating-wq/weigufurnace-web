---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTA from '../../components/CTA.astro';

const { 
  name = "Industrial Kerosene Drip Feeder For Surface Hardening", 
  slug = "kerosene-drip-feeder",
  desc = "Rugged adjustable feeder for kerosene injection into heat treatment furnaces.",
  specs = [
    { label: "Working Pressure", value: "Up to 5 Bar" },
    { label: "Connection Size", value: "Custom Thread / Flange" },
    { label: "Adjustment Type", value: "Micro-Drip Control" },
    { label: "Body Material", value: "SUS304 Stainless Steel" }
  ]
} = Astro.props;
---

<BaseLayout title={name} description={desc}>
  <main class="container mx-auto px-4 py-12">
    <div class="flex flex-col lg:flex-row gap-16 items-start mb-20">
      <div class="flex-1 bg-gray-100 aspect-square rounded-2xl flex items-center justify-center text-gray-400 border-2 border-dashed border-gray-200">
        Product Image: {name}
      </div>
      <div class="flex-1">
        <h1 class="text-4xl font-extrabold text-blue-900 mb-6 leading-tight">{name}</h1>
        <p class="text-lg text-gray-600 mb-8 leading-relaxed">
          You will find that our kerosene drip feeders are the preferred choice for industrial surface hardening lines. Our design ensures that you get a steady, reliable flow of liquid into your furnace chamber, preventing the uneven carbon distribution that plagues lower-quality components. You can improve your factory yield by switching to our precision-machined injection systems today.
        </p>
        
        <div class="bg-blue-900 text-white p-8 rounded-xl mb-8 shadow-xl">
          <h2 class="text-sm font-bold uppercase tracking-widest text-orange-400 mb-4">Technical Specifications</h2>
          <div class="space-y-3">
            {specs.map(spec => (
              <div class="flex justify-between border-b border-blue-800 pb-2">
                <span class="font-medium">{spec.label}</span>
                <span class="text-orange-200 font-bold">{spec.value}</span>
              </div>
            ))}
          </div>
        </div>
        
        <a href="/contact/" class="w-full block bg-orange-600 hover:bg-orange-700 text-white text-center py-4 rounded-lg font-black text-xl transition-all shadow-lg shadow-orange-900/20">
          Request A Technical Quote
        </a>
      </div>
    </div>

    <div class="prose prose-lg max-w-none mb-20">
      <h2 class="text-3xl font-bold text-blue-900 mb-6 border-l-8 border-orange-500 pl-6">Enhanced Process Control For Metal Heat Treatment</h2>
      <p>You require high-performance consumables to maintain the competitive edge of your factory. Our kerosene feeders are built to withstand continuous use in high-temperature environments. Whether you are running a large mesh belt furnace or a specific box furnace, our adjustable drip feeders provide the flexibility and accuracy you need to achieve repeatable metallurgical results every time.</p>
    </div>

    <CTA title={`Improve Your Hardening Results With ${name}`} />
  </main>
</BaseLayout>
