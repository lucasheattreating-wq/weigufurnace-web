---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../data/navigation';

const { 
  name = "Methanol Drip Feeder for Furnace", 
  slug = "methanol-drip-feeder",
  desc = "High-precision adjustable liquid feeding device for heat treatment furnace atmosphere control.",
  specs = [
    { label: "Material", value: "SUS304 / 316L Stainless Steel" },
    { label: "Outlet Configuration", value: "Single / Dual / Three Outlet" },
    { label: "Sight Glass", value: "Industrial Tempered Glass" },
    { label: "Connection Type", value: "Threaded / Flange (Customizable)" }
  ]
} = Astro.props;
---

<BaseLayout title={`${name} | Stainless Steel Drip Feeder`} description={desc}>
  <div class="bg-white py-12 border-b border-gray-100">
    <div class="container mx-auto px-4">
      <nav class="text-sm text-gray-500 mb-8 flex gap-2">
        <a href="/" class="hover:text-accent">Home</a> / 
        <a href="/consumables/" class="hover:text-accent">Consumables</a> / 
        <span class="text-gray-900 font-medium">{name}</span>
      </nav>

      <div class="flex flex-col lg:flex-row gap-16">
        <!-- Product Image (Polycase Style) -->
        <div class="flex-1">
          <div class="bg-gray-50 aspect-square rounded-2xl border border-gray-200 flex items-center justify-center text-gray-400 shadow-inner group">
             <span class="text-sm group-hover:scale-110 transition-transform">Placeholder: {name} HD Image</span>
          </div>
        </div>

        <!-- Product Summary -->
        <div class="flex-1">
          <h1 class="text-4xl font-extrabold text-primary mb-6 leading-tight">{name}</h1>
          <div class="prose prose-slate mb-10 text-gray-600">
             <p>
                You are looking for a reliable way to maintain furnace atmosphere stability. Our {name} is engineered to deliver precise liquid methanol or kerosene feeding. It ensures consistent drip rates even in demanding heat treatment environments.
             </p>
          </div>

          <div class="bg-primary/5 p-6 rounded-xl border border-primary/10 mb-8">
            <h2 class="text-lg font-bold text-primary mb-4 uppercase tracking-wider text-sm">Key Specifications</h2>
            <div class="grid grid-cols-1 gap-3">
              {specs.map(spec => (
                <div class="flex justify-between border-b border-gray-200 py-2">
                  <span class="text-gray-500 font-medium">{spec.label}</span>
                  <span class="text-primary font-bold">{spec.value}</span>
                </div>
              ))}
            </div>
          </div>

          <a href="/contact/#quote-form" class="w-full block bg-accent hover:bg-orange-600 text-white text-center py-4 rounded-lg font-black text-lg transition-all shadow-lg shadow-accent/20">
            Request A Quote For This Item
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Detailed Content (Checklist Rule: 50-80 words per block) -->
  <section class="py-20 bg-gray-50">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="space-y-16">
        <article>
          <h2 class="text-2xl font-bold mb-6 text-primary border-l-4 border-accent pl-4 uppercase">Reliable Atmosphere Control Applications</h2>
          <p class="leading-relaxed text-gray-600">
            You can use this drip feeder for various furnace types including pit furnaces and mesh belt carburizing lines. Our design focuses on the stability of the liquid feeding process, which is critical for atmosphere adjustment. Whether you need a single outlet for a small box furnace or a triple outlet for complex systems, our precision needle valves allow for micro-adjustments.
          </p>
        </article>

        <article>
          <h2 class="text-2xl font-bold mb-6 text-primary border-l-4 border-accent pl-4 uppercase">Durable Industrial Grade Construction</h2>
          <p class="leading-relaxed text-gray-600">
            You deserve components that last. We manufacture each drip feeder with high-grade stainless steel to resist corrosion and thermal stress. The tempered sight glass provides a clear view of the drip rate without risking safety under high-pressure conditions. We provide a full range of spare parts including PTFE gaskets and custom-length insertion tubes to match your specific installation requirements.
          </p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
