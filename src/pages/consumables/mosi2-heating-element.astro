---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTA from '../../components/CTA.astro';

const { 
  name = "Molybdenum Disilicide MoSi2 Heating Element", 
  slug = "mosi2-heating-element",
  desc = "High-purity MoSi2 elements for temperatures up to 1800°C.",
  specs = [
    { label: "Grades", value: "1700, 1800, 1850 Series" },
    { label: "Max Temp", value: "1850°C (Oxidizing Atmosphere)" },
    { label: "Shaping", value: "U, W, L-Type / Custom" },
    { label: "Resistance", value: "Consistent Life Cycle" }
  ]
} = Astro.props;
---

<BaseLayout title={name} description={desc}>
  <main class="container mx-auto px-4 py-12">
    <div class="flex flex-col lg:flex-row gap-16 items-start mb-20">
      <div class="flex-1 bg-gray-100 aspect-square rounded-2xl flex items-center justify-center text-gray-400 border-2 border-dashed border-gray-200">
        Product Image: {name}
      </div>
      <div class="flex-1">
        <h1 class="text-4xl font-extrabold text-blue-900 mb-6 leading-tight">{name}</h1>
        <p class="text-lg text-gray-600 mb-8 leading-relaxed">
          You will experience unparalleled reliability when you choose Weigu for your furnace accessory needs. Our commitment to precision engineering means you get equipment that lasts longer and performs better under pressure. You can maximize your ROI with our durable designs and reduce operational costs in your workshop starting from today.
        </p>
        
        <div class="bg-blue-900 text-white p-8 rounded-xl mb-8 shadow-xl">
          <h2 class="text-sm font-bold uppercase tracking-widest text-orange-400 mb-4">Technical Specifications</h2>
          <div class="space-y-3">
            {specs.map(spec => (
              <div class="flex justify-between border-b border-blue-800 pb-2">
                <span class="font-medium">{spec.label}</span>
                <span class="text-orange-200 font-bold">{spec.value}</span>
              </div>
            ))}
          </div>
        </div>
        
        <a href="/contact/" class="w-full block bg-orange-600 hover:bg-orange-700 text-white text-center py-4 rounded-lg font-black text-xl transition-all shadow-lg shadow-orange-900/20">
          Request A Technical Quote
        </a>
      </div>
    </div>

    <div class="prose prose-lg max-w-none mb-20">
      <h2 class="text-3xl font-bold text-blue-900 mb-6 border-l-8 border-orange-500 pl-6">Maximize Your Process Stability</h2>
      <p>You deserve heating solutions that match the complexity of your metal processing needs. Our components are designed to ensure your process stays stable and repeatable, minimizing the downtime of your high-capacity carburizing or laboratory furnaces. Every Weigu product is verified to withstand the demanding conditions of your industrial facility.</p>
    </div>

    <CTA title={`Enhance Your Thermal Process With ${name}`} />
  </main>
</BaseLayout>
