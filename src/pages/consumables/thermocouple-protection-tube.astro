---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTA from '../../components/CTA.astro';

const { 
  name = "Industrial Thermocouple Protection Tube For High Temp", 
  slug = "thermocouple-protection-tube",
  desc = "Durable protection tubes in ceramic or alloy for furnace sensors.",
  specs = [
    { label: "Materials", value: "Alumina / Silicon Carbide / Alloy" },
    { label: "Max Temp", value: "Up to 1800°C" },
    { label: "Dimensions", value: "Custom Length & Diameter" },
    { label: "Gas Tightness", value: "100% Hermetically Sealed" }
  ]
} = Astro.props;
---

<BaseLayout title={name} description={desc}>
  <main class="container mx-auto px-4 py-12">
    <div class="flex flex-col lg:flex-row gap-16 items-start mb-20">
      <div class="flex-1 bg-gray-100 aspect-square rounded-2xl flex items-center justify-center text-gray-400 border-2 border-dashed border-gray-200">
        Product Image: {name}
      </div>
      <div class="flex-1">
        <h1 class="text-4xl font-extrabold text-blue-900 mb-6 leading-tight">{name}</h1>
        <p class="text-lg text-gray-600 mb-8 leading-relaxed">
          You depend on accurate temperature feedback to protect your valuable furnace charges. Our {name} ensures that your sensors are shielded from thermal shock, chemical corrosion, and mechanical damage. You will experience fewer thermocouple failures and more consistent temperature readings across your heat treatment cycles by choosing our specialized protection solutions for your industrial furnace today.
        </p>
        
        <div class="bg-blue-900 text-white p-8 rounded-xl mb-8 shadow-xl">
          <h2 class="text-sm font-bold uppercase tracking-widest text-orange-400 mb-4">Technical Specifications</h2>
          <div class="space-y-3">
            {specs.map(spec => (
              <div class="flex justify-between border-b border-blue-800 pb-2">
                <span class="font-medium">{spec.label}</span>
                <span class="text-orange-200 font-bold">{spec.value}</span>
              </div>
            ))}
          </div>
        </div>
        
        <a href="/contact/" class="w-full block bg-orange-600 hover:bg-orange-700 text-white text-center py-4 rounded-lg font-black text-xl transition-all shadow-lg shadow-orange-900/20">
          Request A Technical Quote
        </a>
      </div>
    </div>

    <div class="prose prose-lg max-w-none mb-20">
      <h2 class="text-3xl font-bold text-blue-900 mb-6 border-l-8 border-orange-500 pl-6">Protect Your Sensors In Extreme Environments</h2>
      <p>You require high-purity materials to prevent contamination in your vacuum or protective atmosphere furnaces. Our protection tubes are sourced from certified manufacturers to guarantee thermal stability at temperatures exceeding 1600°C. From specialized pit furnace probes to standard box furnace sensors, Weigu provides the exact protection tube configuration your facility needs to maintain process integrity.</p>
    </div>

    <CTA title={`Secure Your Temperature Control With ${name}`} />
  </main>
</BaseLayout>
