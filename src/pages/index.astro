---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/navigation';

const categories = [
  { name: 'Atmosphere Control', desc: 'Liquid drip feeders and flow control for carburizing processes.', icon: 'M', href: '/consumables/methanol-drip-feeder/' },
  { name: 'Temperature Measurement', desc: 'Precision thermocouple connection parts and insulation tubes.', icon: 'T', href: '/consumables/thermocouple-protection-tube/' },
  { name: 'Insulation & Lining', desc: 'High-temperature ceramic fiber blankets and fixings.', icon: 'I', href: '/consumables/ceramic-fiber-board/' },
  { name: 'Testing & Recording', desc: 'Process verification rings and hardness testing supplies.', icon: 'V', href: '/consumables/heat-treatment-verification-ring/' }
];
---

<BaseLayout title="Heat Treatment Furnace Accessories & Consumables" description="Leading expert in heat treatment furnace process stability. Sourcing atmosphere control kits, temperature measurement probes, and insulation materials.">
  
  <!-- Hero Section (Polycase Style) -->
  <section class="relative bg-white border-b border-gray-100 overflow-hidden">
    <div class="container mx-auto px-4 py-24 flex flex-col md:flex-row items-center gap-16">
      <div class="flex-1 text-center md:text-left">
        <p class="text-accent font-bold uppercase tracking-widest text-sm mb-4">Furnace Process Stability Specialist</p>
        <h1 class="text-4xl md:text-6xl font-extrabold text-primary mb-8 leading-tight">
          Precision Consumables For Heat Treatment Furnaces
        </h1>

        <!-- 1200x600 Premium Industrial Product Kit Shot Placeholder -->
        <div class="w-full aspect-[2/1] bg-slate-100 rounded-3xl mb-12 border border-slate-200 overflow-hidden shadow-inner flex items-center justify-center relative group">
           <div class="absolute inset-0 bg-gradient-to-t from-slate-900/10 to-transparent"></div>
           <div class="flex flex-col items-center gap-4 text-slate-400">
              <span class="text-6xl opacity-30">📐</span>
              <span class="text-xs uppercase font-bold tracking-[0.2em] opacity-40 italic">1200x600 Premium Industrial Product Kit Shot</span>
           </div>
        </div>

        <p class="text-lg text-gray-600 mb-10 max-w-xl leading-relaxed">
          You need reliable atmosphere control and temperature measurement to ensure high-quality results. WEIGU provides industrial-grade accessories designed for pit furnaces, box furnaces, and mesh belt lines.
        </p>
        <div class="flex flex-wrap gap-4 justify-center md:justify-start">
          <a href="/consumables/" class="bg-primary text-white px-8 py-3 rounded-md font-bold hover:bg-blue-900 transition-all shadow-lg">Browse Consumables</a>
          <a href="/contact/" class="border-2 border-primary text-primary px-8 py-3 rounded-md font-bold hover:bg-gray-50 transition-all">Get Technical Support</a>
        </div>
      </div>
      <div class="flex-1 relative">
        <div class="bg-gray-100 aspect-video rounded-lg shadow-inner flex items-center justify-center border-2 border-dashed border-gray-200 text-gray-400">
          <span class="text-sm">Placeholder: Furnace Atmosphere Control Retrofit Kit Image</span>
        </div>
        <div class="absolute -bottom-6 -left-6 bg-accent text-white p-4 shadow-xl hidden lg:block rounded-tr-3xl">
          <p class="text-xs uppercase font-bold tracking-tighter">Certified Quality</p>
          <p class="text-lg font-bold">Reliable Source</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Category Grid (Polycase Sidebar Context) -->
  <section class="py-20 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="flex flex-col md:flex-row gap-12">
        
        <!-- Sidebar Navigation (Polycase Style) -->
        <aside class="w-full md:w-64 flex-shrink-0">
          <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden sticky top-24">
            <h2 class="bg-primary text-white px-4 py-3 text-sm font-bold uppercase tracking-wider">Top Categories</h2>
            <nav class="p-2 space-y-1">
              {categories.map(cat => (
                <a href={cat.href} class="block px-4 py-2 text-sm text-gray-700 hover:bg-accent/10 hover:text-accent rounded transition-all font-medium">
                  {cat.name}
                </a>
              ))}
            </nav>
          </div>
        </aside>

        <!-- Main Content Block -->
        <div class="flex-1">
          <h2 class="text-2xl font-bold mb-10 text-primary border-l-4 border-accent pl-4">Shop By Category</h2>
          <div class="grid sm:grid-cols-2 gap-8">
            {categories.map(cat => (
              <a href={cat.href} class="group bg-white p-6 rounded-2xl shadow-sm border border-gray-100 hover:border-accent hover:shadow-2xl transition-all flex flex-col items-center text-center gap-6">
                <!-- 200x200 large icons with gray modeling background -->
                <div class="w-[200px] h-[200px] bg-slate-100 flex items-center justify-center rounded-xl border border-slate-200 group-hover:bg-white transition-colors overflow-hidden relative">
                  <div class="absolute inset-0 bg-gradient-to-br from-slate-200/50 to-transparent"></div>
                  <span class="text-6xl group-hover:scale-110 transition-transform duration-500 relative z-10">{cat.icon}</span>
                  <div class="absolute bottom-4 left-0 right-0 text-[8px] uppercase font-bold tracking-[0.3em] opacity-20 italic">Industrial 3D View</div>
                </div>
                <div>
                  <h3 class="text-xl font-bold mb-3 group-hover:text-accent transition-colors">{cat.name}</h3>
                  <p class="text-sm text-gray-500 leading-relaxed max-w-[250px]">{cat.desc}</p>
                </div>
              </a>
            ))}
          </div>

          <!-- Content Block (Checklist 50-80 words rule) -->
          <article class="mt-20 prose prose-slate max-w-none">
            <h2 class="text-3xl font-bold mb-8">Maintain Process Stability With Precision Accessories</h2>
            <div class="bg-white p-10 rounded-2xl border border-gray-100 shadow-sm leading-relaxed text-gray-600">
              <p>
                You understand that even the smallest failure in atmosphere control or temperature measurement can lead to costly quality issues. Our mission at WEIGU is to help you mitigate these risks by providing high-quality furnace consumables that ensure consistent performance. Whether you are running a carburizing pit furnace or a large-scale mesh belt heat treatment line, our expert-sourced parts offer the durability your factory demands.
              </p>
            </div>
          </article>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA Box (Polycase Style) -->
  <section class="bg-primary py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-white text-3xl font-bold mb-6">Need Custom Furnace Accessories?</h2>
      <p class="text-gray-300 mb-10 max-w-2xl mx-auto">
        Please provide your furnace type, working temperature, and specific requirements. Our technical team will provide a tailored configuration for your process.
      </p>
      <a href="/contact/" class="bg-accent text-white px-10 py-4 rounded font-extrabold hover:scale-105 transition-transform inline-block">Request A Technical Quote</a>
    </div>
  </section>

</BaseLayout>

