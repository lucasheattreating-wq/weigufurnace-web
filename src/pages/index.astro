---
import BaseLayout from '../layouts/BaseLayout.astro';
import { images, features } from '../data/site';
---

<BaseLayout 
  title="High-Precision Methanol Dropper for Industrial Furnaces" 
  description="Adjustable stainless steel drip feeder for controlled methanol and kerosene liquid feeding."
>
  <!-- Hero Section -->
  <section class="section section-alt" style="padding: 6rem 0;">
    <div class="container hero-grid">
      <div class="hero-content">
        <p style="color: var(--accent); font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem;">Atmosphere Control Precision</p>
        <h1>Methanol Dropper for Furnace Systems</h1>
        <p style="font-size: 1.25rem; color: var(--text-muted); margin-bottom: 2.5rem; max-width: 600px;">
          Engineered for stability. Our stainless steel drip feeders provide precise liquid delivery for carburizing and protective atmosphere furnaces.
        </p>
        <div class="hero-btns" style="display: flex; gap: 1rem;">
          <a href="/contact-us/" class="btn btn-primary">Request Quote</a>
          <a href="/products/methanol-dropper-for-furnace/" class="btn btn-outline">Technical Specs</a>
        </div>
      </div>
      <div>
        <div style="background: white; padding: 1rem; border-radius: 12px; box-shadow: var(--shadow);">
          <img src={images.hero} alt="Methanol Dropper Hero" style="width: 100%; border-radius: 8px; display: block;" />
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Features -->
  <section class="section">
    <div class="container">
      <div style="text-align: center; max-width: 800px; margin: 0 auto 4rem;">
        <h2>Premium Engineering Features</h2>
      </div>
      <div class="grid grid-3">
        {features.slice(0, 6).map((feature) => (
          <div class="card">
            <div style="width: 40px; height: 40px; background: var(--bg-alt); border-radius: 8px; display: flex; align-items: center; justify-content: center; margin-bottom: 1.5rem;">
              <span style="color: var(--accent); font-weight: 700;">✓</span>
            </div>
            <h3>{feature}</h3>
            <p style="color: var(--text-muted); font-size: 0.95rem; margin-top: 1rem;">Optimized for high-performance furnace atmosphere control.</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
