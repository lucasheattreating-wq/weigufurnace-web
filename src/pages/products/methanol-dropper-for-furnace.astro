---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { images, features } from '../../data/site';
---

<BaseLayout title="Methanol Dropper for Furnace" description="Technical specifications for our high-precision stainless steel drip feeder.">
  <section class="section">
    <div class="container grid grid-2" style="align-items: center;">
      <div>
        <h1 style="font-size: 2.5rem;">Methanol Dropper for Furnace</h1>
        <p style="margin-bottom: 2rem; color: var(--text-muted);">Industrial grade stainless steel adjustable drip feeder for carburizing and heat treatment furnaces.</p>
        <div style="background: var(--bg-alt); padding: 1.5rem; border-radius: 12px; margin-bottom: 2rem;">
          <h4 style="margin-bottom: 1rem;">Technical Overview</h4>
          <ul style="list-style: none; display: grid; gap: 0.5rem;">
            {features.map(f => <li style="display: flex; gap: 0.5rem;"><span style="color: var(--accent);">●</span> {f}</li>)}
          </ul>
        </div>
        <a href="/contact-us/" class="btn btn-primary">Request Technical Datasheet</a>
      </div>
      <div>
        <img src={images.productMain} alt="Product Detail" style="width: 100%; border-radius: 12px; box-shadow: var(--shadow);" />
      </div>
    </div>
  </section>
</BaseLayout>
