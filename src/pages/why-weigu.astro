---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Why Choose WEIGU | Industrial Furnace Accessories Specialist">
  <main class="container mx-auto px-4 py-16">
    <div class="max-w-4xl mx-auto">
      <p class="text-orange-600 font-bold uppercase tracking-widest text-sm mb-4">Precision & Reliability</p>
      <h1 class="text-4xl md:text-5xl font-extrabold text-blue-900 mb-8 leading-tight">Why Choose WEIGU?</h1>
      
      <div class="prose prose-lg max-w-none text-gray-600 mb-12">
        <p>
          At WEIGU, we don't just sell accessories; we provide the stability your heat treatment furnace needs to operate at peak efficiency. With over 20 years of expertise and a focus on zero-risk procurement, we have become the trusted partner for over 500 factories worldwide.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
          <h2 class="text-xl font-bold text-blue-900 mb-4">Exclusive Carburizing Solutions</h2>
          <p class="text-gray-600">
            We are a market leader in carburizing furnace parts, offering exclusive atmosphere control kits and methanol droppers that you won't find anywhere else.
          </p>
        </div>
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
          <h2 class="text-xl font-bold text-blue-900 mb-4">30% Better Value</h2>
          <p class="text-gray-600">
            Our ceramic fiber series and thermal insulation products are priced up to 30% lower than major competitors without compromising on quality or performance.
          </p>
        </div>
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
          <h2 class="text-xl font-bold text-blue-900 mb-4">Safety First PPE</h2>
          <p class="text-gray-600">
            We fill the gap in the market for high-temperature personal protective equipment, ensuring your operators are safe with aluminized gloves and heat-shield face shields.
          </p>
        </div>
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
          <h2 class="text-xl font-bold text-blue-900 mb-4">Research Grade Quality</h2>
          <p class="text-gray-600">
            Our 99.5% Alumina crucibles and tubes are the gold standard for universities and research centers, designed for precise material processing.
          </p>
        </div>
      </div>

      <section class="bg-blue-900 text-white p-10 rounded-3xl shadow-xl">
        <h2 class="text-3xl font-bold mb-6">Our Core Advantages</h2>
        <ul class="space-y-4">
          <li class="flex items-start">
            <span class="text-orange-400 mr-2">✔</span>
            <span><strong>Zero-Risk Procurement:</strong> Products are standardized and verified to ensure they won't damage your equipment.</span>
          </li>
          <li class="flex items-start">
            <span class="text-orange-400 mr-2">✔</span>
            <span><strong>Global Logistics:</strong> Fast shipping via DHL/FedEx for small items and optimized sea freight for bulk orders.</span>
          </li>
          <li class="flex items-start">
            <span class="text-orange-400 mr-2">✔</span>
            <span><strong>Technical Support:</strong> Deep knowledge of atmosphere control and temperature measurement to guide your selection.</span>
          </li>
        </ul>
      </section>
      
      <div class="mt-12 text-center">
        <a href="/about-us/" class="inline-block bg-orange-600 hover:bg-orange-700 text-white font-bold py-4 px-10 rounded-full transition-colors shadow-lg">
          Learn More About Us
        </a>
      </div>
    </div>
  </main>
</BaseLayout>