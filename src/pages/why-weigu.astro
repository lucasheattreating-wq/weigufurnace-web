---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Why Choose Weigu Furnace">
  <main class="container mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold mb-6">Why Choose Weigu Furnace</h1>
    <p class="text-lg mb-8">
      You will experience unparalleled reliability when you choose Weigu Furnace for your industrial needs. Our commitment to precision engineering means You get equipment that lasts longer and performs better under pressure. You can maximize your ROI with our energy-efficient designs and reduce operational costs significantly. We stand by you with comprehensive support, ensuring your furnace operations are always running at peak performance.
    </p>

    <div class="space-y-8">
      <div class="flex gap-4">
        <div class="bg-blue-100 p-3 rounded-full h-fit text-blue-600 font-bold">1</div>
        <div>
          <h3 class="text-xl font-bold">Advanced Thermal Control</h3>
          <p>You get precise temperature management for critical heat treatment processes.</p>
        </div>
      </div>
      <div class="flex gap-4">
        <div class="bg-blue-100 p-3 rounded-full h-fit text-blue-600 font-bold">2</div>
        <div>
          <h3 class="text-xl font-bold">Durable Construction</h3>
          <p>You can rely on heavy-duty materials built for long-term industrial use.</p>
        </div>
      </div>
      <div class="flex gap-4">
        <div class="bg-blue-100 p-3 rounded-full h-fit text-blue-600 font-bold">3</div>
        <div>
          <h3 class="text-xl font-bold">Customized Solutions</h3>
          <p>You will receive a system tailored to your specific workshop layout and requirements.</p>
        </div>
      </div>
    </div>

    <div class="mt-16 text-center border-t pt-8">
      <p class="text-xl mb-6">Ready to upgrade your thermal processing?</p>
      <div class="flex justify-center gap-4">
        <a href="/consumables" class="bg-blue-600 text-white px-8 py-3 rounded-lg font-bold">View Consumables</a>
        <a href="/about-us" class="border border-blue-600 text-blue-600 px-8 py-3 rounded-lg font-bold">Learn About Us</a>
      </div>
    </div>
  </main>
</BaseLayout>
